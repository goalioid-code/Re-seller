# Environment Variables - Admin Web CALSUB (Example)
# Salin file ini menjadi .env.local dan isi dengan nilai sebenarnya

# Supabase (self-host di VPS)
VITE_SUPABASE_URL=https://your-vps-host:8443
VITE_SUPABASE_ANON_KEY=your-anon-jwt-from-supabase-docker-env

# Backend API
VITE_API_URL=http://localhost:3000

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# App
VITE_NODE_ENV=development
