generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reseller {
  id                 String                 @id @default(uuid())
  google_id          String                 @unique
  email              String                 @unique
  name               String
  photo_url          String?
  phone              String?
  address            String?
  status             String                 @default("pending")
  tier_id            String?
  onboarding_data    String?
  fcm_token          String?
  created_at         DateTime               @default(now())
  updated_at         DateTime               @updatedAt
  withdrawals        CommissionWithdrawal[]
  commissions        Commission[]
  notifications      Notification[]
  orders             Order[]
  points             Point[]
  tier               CommissionTier?        @relation(fields: [tier_id], references: [id])
  reward_redemptions RewardRedemption[]

  @@map("resellers")
}

model CommissionTier {
  id         String     @id @default(uuid())
  name       String
  percentage Float
  min_orders Int        @default(0)
  is_active  Boolean    @default(true)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  resellers  Reseller[]

  @@map("commission_tiers")
}

model Commission {
  id           String    @id @default(uuid())
  reseller_id  String
  order_id     String?
  amount       Float
  percentage   Float
  status       String    @default("pending")
  note         String?
  created_at   DateTime  @default(now())
  confirmed_at DateTime?
  reseller     Reseller  @relation(fields: [reseller_id], references: [id])

  @@map("commissions")
}

model CommissionWithdrawal {
  id           String    @id @default(uuid())
  reseller_id  String
  amount       Float
  status       String    @default("pending")
  bank_name    String?
  bank_account String?
  account_name String?
  notes        String?
  admin_notes  String?
  created_at   DateTime  @default(now())
  processed_at DateTime?
  reseller     Reseller  @relation(fields: [reseller_id], references: [id])

  @@map("commission_withdrawals")
}

model Point {
  id          String    @id @default(uuid())
  reseller_id String
  order_id    String?
  amount      Int
  type        String
  note        String?
  expires_at  DateTime?
  created_at  DateTime  @default(now())
  reseller    Reseller  @relation(fields: [reseller_id], references: [id])

  @@map("points")
}

model Reward {
  id          String             @id @default(uuid())
  name        String
  description String?
  image_url   String?
  points_cost Int
  stock       Int                @default(0)
  is_active   Boolean            @default(true)
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt
  redemptions RewardRedemption[]

  @@map("rewards")
}

model RewardRedemption {
  id           String    @id @default(uuid())
  reseller_id  String
  reward_id    String
  points_used  Int
  status       String    @default("pending")
  address      String?
  notes        String?
  admin_notes  String?
  created_at   DateTime  @default(now())
  processed_at DateTime?
  reseller     Reseller  @relation(fields: [reseller_id], references: [id])
  reward       Reward    @relation(fields: [reward_id], references: [id])

  @@map("reward_redemptions")
}

model Notification {
  id          String   @id @default(uuid())
  reseller_id String
  type        String
  title       String
  body        String
  is_read     Boolean  @default(false)
  data        String?
  created_at  DateTime @default(now())
  reseller    Reseller @relation(fields: [reseller_id], references: [id])

  @@map("notifications")
}

model Order {
  id                  String             @id @default(uuid())
  reseller_id         String
  po_number           String             @unique
  order_type          String
  customer_name       String
  brand_name          String
  order_date          DateTime
  due_date            DateTime
  description         String?
  notes               String?
  subtotal            Float              @default(0)
  discount            Float              @default(0)
  total_amount        Float              @default(0)
  status              String             @default("draft")
  lk_approved         Boolean            @default(false)
  design_file_url     String?
  mockup_file_url     String?
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
  items               OrderItem[]
  payments            OrderPayment[]
  reseller            Reseller           @relation(fields: [reseller_id], references: [id])
  production_statuses ProductionStatus[]
  work_order          WorkOrder?

  @@map("orders")
}

model OrderItem {
  id               String   @id @default(uuid())
  order_id         String
  product_name     String
  quantity         Int
  unit_price       Float
  collar_type      String?
  pattern          String?
  fabric_type      String?
  additional_attrs String?
  subtotal         Float    @default(0)
  created_at       DateTime @default(now())
  order            Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model OrderPayment {
  id                      String    @id @default(uuid())
  order_id                String
  payment_type            String
  amount                  Float
  required_amount         Float
  midtrans_order_id       String?
  midtrans_transaction_id String?
  payment_method          String?
  status                  String    @default("pending")
  proof_url               String?
  created_at              DateTime  @default(now())
  completed_at            DateTime?
  order                   Order     @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_payments")
}

model WorkOrder {
  id                   String    @id @default(uuid())
  order_id             String    @unique
  lk_number            String    @unique
  size_run             String?
  back_name            String?
  back_number          String?
  additional_details   String?
  status               String    @default("draft")
  approved_at          DateTime?
  approved_by_reseller Boolean   @default(false)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  order                Order     @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("work_orders")
}

model ProductionStage {
  id                  String             @id @default(uuid())
  name                String
  order_index         Int
  description         String?
  created_at          DateTime           @default(now())
  production_statuses ProductionStatus[]

  @@map("production_stages")
}

model ProductionStatus {
  id               String          @id @default(uuid())
  order_id         String
  stage_id         String
  status           String
  started_at       DateTime?
  completed_at     DateTime?
  duration_minutes Int?
  notes            String?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  order            Order           @relation(fields: [order_id], references: [id], onDelete: Cascade)
  stage            ProductionStage @relation(fields: [stage_id], references: [id])

  @@map("production_statuses")
}

model Admin {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  name          String
  role          String
  permissions   String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("admins")
}
